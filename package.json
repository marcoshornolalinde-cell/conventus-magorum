{
  "name": "chapas-el-encuentro-headless",
  "version": "0.1.0",
  "private": true,
  "description": "Motor headless TypeScript para juego de cartas.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "selfplay": "tsx src/cli/selfplay.ts",
    "ui:snapshot": "tsx src/cli/exportUiSnapshot.ts",
    "simulate": "tsx src/cli/simulate.ts",
